{
  "version": "0.1.0",
  "configurations": [
    {
      "name": "Python: Remote Attach (VanTrack)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/code"
        }
      ],
      "justMyCode": true
    }
  ]
}